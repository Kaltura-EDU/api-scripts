# SESSION VARIABLES -----------------------------------------------------------

# Your Kaltura Partner ID (integer, found in KMC under Settings > Integration Settings)
PARTNER_ID=

# Admin secret is entered at runtime via a secure prompt — do not store it here

# User ID associated with your Kaltura account (typically your email address)
USER_ID=

# Session privileges passed to the Kaltura API
PRIVILEGES=all:*,disableentitlement

# SCRIPT VARIABLES ------------------------------------------------------------

# ID of the metadata profile used for CategoryAdditionalInfo
# Found in KMC under Settings > Custom Data
METADATA_PROFILE_ID=

# Identify the source and destination channels using EITHER the category ID OR
# the channel name — not both. If both are set for either channel, the script
# will exit with an error.

# Source channel (contains the playlists you want to duplicate)
SOURCE_CATEGORY_ID=
SOURCE_CATEGORY_NAME=

# Destination channel (where the duplicated playlists will be assigned)
DESTINATION_CATEGORY_ID=
DESTINATION_CATEGORY_NAME=
