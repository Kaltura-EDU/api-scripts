# Kaltura Credentials
PARTNER_ID=your_partner_id_here
ADMIN_SECRET=your_admin_secret_here
USER_ID=your_api_user_id_here
SERVICE_URL=https://www.kaltura.com

# MediaSpace channel parent category and settings
# PARENT_ID is the category ID of the MediaSpace channels root (e.g. MediaSpace>site>channels)
PARENT_ID=your_channels_parent_category_id_here
PRIVACY_CONTEXT=MediaSpace
FULL_NAME_PREFIX=MediaSpace>site>channels>
MEDIA_SPACE_BASE_URL=https://your.mediaspace.domain/channel/

# Channel creation defaults
CHANNEL_PRIVACY=3
USER_JOIN_POLICY=3
APPEAR_IN_LIST=3
INHERITANCE_TYPE=2
DEFAULT_PERMISSION_LEVEL=3
CONTRIBUTION_POLICY=2
MODERATION=0

# Canvas category prefix — the full Kaltura category path up to (not including) the course ID
CANVAS_CAT_PREFIX=Canvas_Prod>site>channels>

# Input CSV files (can also be passed as CLI args to override these)
COURSES_CSV_FILENAME=input/canvas_sp26_courses.csv
USERS_CSV_FILENAME=input/canvas_sp26_users.csv

# Number of courses to process concurrently (each thread opens its own session).
# Raise cautiously — aggressive concurrency may trigger Kaltura rate limits.
# Recommended range: 3–10.
THREAD_COUNT=5

# Parallelism within each course for member additions and entry publications.
# With THREAD_COUNT=5 and MEMBER_THREADS=10 you get up to 50 concurrent
# Kaltura requests. Recommended range: 5–15.
MEMBER_THREADS=10

# Kaltura session TTL in seconds. Default 86400 = 24 hours.
SESSION_EXPIRY=86400

# Total API call attempts per operation (1 = no retry, 4 = 3 retries).
# Uses exponential backoff. Permanent errors (duplicates, etc.) are not retried.
MAX_RETRIES=4
