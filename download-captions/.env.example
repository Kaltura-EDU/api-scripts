# SESSION VARIABLES -----------------------------------------------------------

# Your Kaltura partner ID (found in KMC under Settings > Integration Settings)
PARTNER_ID=

# The Kaltura service URL
KALTURA_SERVICE_URL=https://www.kaltura.com/

# Optional Kaltura user ID for audit logs (e.g., api-username)
KALTURA_USER=

# SCRIPT VARIABLES ------------------------------------------------------------

# Folder where downloaded captions will be saved
DOWNLOAD_FOLDER=output

# Controls what gets saved: srt (default), txt, or both
OUTPUT_FORMAT=srt

# Set to true to include entries from subcategories when filtering by category ID
INCLUDE_CHILD_CATEGORIES=true

# Set to false to exclude caption labels from filenames (shorter filenames)
INCLUDE_CAPTION_LABEL_IN_FILENAMES=true

# Set to true to skip child entries in multi-stream entries
SKIP_CHILD_ENTRIES=true

# Set to true to enable debug output for troubleshooting
DEBUG=false

# QUERY FILTERS ---------------------------------------------------------------
# Set one. If multiple are set, priority order is: ENTRY_IDS > CATEGORY_IDS > TAGS > OWNER.

CATEGORY_IDS=
TAGS=
ENTRY_IDS=
OWNER=
