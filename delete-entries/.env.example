# -----------------------------------------------------------------------------
# SESSION VARIABLES -----------------------------------------------------------
# -----------------------------------------------------------------------------

PARTNER_ID=
ADMIN_SECRET=
USER_ID=                          # optional, but recommended for audits
SERVICE_URL=https://www.kaltura.com
PRIVILEGES=all:*,disableentitlement

# -----------------------------------------------------------------------------
# SEARCH VARIABLES ------------------------------------------------------------
# Use either search terms OR a CSV - not both. --------------------------------
# -----------------------------------------------------------------------------

ENTRY_IDS=

# ⬆️ OR ⬇️

CSV_FILENAME=
# ⬇ the name column header in your CSV that has entry IDs
ENTRY_ID_COLUMN_HEADER=

DRY_RUN=true

MAX_WORKERS=10
REQUEST_TIMEOUT_SEC=30
REQUEST_CONNECT_TIMEOUT_SEC=10

# Set to false to skip the entry lookup phase and go straight to deletion.
# Faster, but result CSV will not have entry name, owner, duration, or plays.
LOOKUP_BEFORE_ACTION=true

# Set to true to pass force=1 to the delete call. Use for entries in error
# states that return ACTION_BLOCKED with a normal delete.
FORCE_DELETE=false