# SESSION VARIABLES -----------------------------------------------------------

# Your Kaltura Partner ID (found in KMC under Settings > Integration Settings)
PARTNER_ID=

# Admin secret is entered at runtime via a secure prompt — do not store it here

# User ID for the Kaltura session (optional; recommended for audit logs)
USER_ID=

# Kaltura API service URL
SERVICE_URL=https://www.kaltura.com

# Session privileges passed to the Kaltura API
PRIVILEGES=all:*,disableentitlement

# SCRIPT VARIABLES ------------------------------------------------------------

# Comma-separated list of entry IDs to delete or recycle
# Use either ENTRY_IDS or CSV_FILENAME — not both
ENTRY_IDS=

# OR: filename of a CSV containing entry IDs (relative to script directory)
CSV_FILENAME=
# The column header in the CSV that contains the entry IDs
ENTRY_ID_COLUMN_HEADER=

# Set to true to preview what would be deleted without making any API calls
DRY_RUN=true

# Set to false to skip the entry lookup phase and go straight to deletion.
# Faster, but the result CSV will not include entry name, owner, duration,
# or plays.
LOOKUP_BEFORE_ACTION=true

# Set to true to pass force=1 to the delete call. Use for entries in error
# states that return ACTION_BLOCKED with a normal delete.
FORCE_DELETE=false

# Number of concurrent API calls.
# Default is 1; 10 is a reasonable value for large batches.
MAX_WORKERS=10

# Timeout settings (in seconds)
REQUEST_TIMEOUT_SEC=30
REQUEST_CONNECT_TIMEOUT_SEC=10
