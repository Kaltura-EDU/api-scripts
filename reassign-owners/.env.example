# -----------------------------------------------------------------------------
# Kaltura API Credentials
# -----------------------------------------------------------------------------
PARTNER_ID=
ADMIN_SECRET=
USER_ID=
SERVICE_URL=https://www.kaltura.com/
PRIVILEGES=all:*,disableentitlement

# -----------------------------------------------------------------------------
# Input Configuration
# -----------------------------------------------------------------------------
# Path to the input CSV
INPUT_FILENAME=input.csv

# MODE determines how ownership is reassigned:
# - owner_map: CSV of old_user -> new_user (reassigns ALL entries owned by each old user)
# - entry_map: CSV of entry_id -> owner_new (reassigns ONLY the listed entry IDs)
# - tag:       Finds all entries with TAG and reassigns them to TAG_NEW_OWNER (no CSV needed)
MODE=owner_map

# --- owner_map headers ---
# Column headers expected in the input CSV when MODE=owner_map
COLUMN_HEADER_OLD=old_username
COLUMN_HEADER_NEW=new_username

# --- entry_map headers ---
# Column headers expected in the input CSV when MODE=entry_map
COLUMN_HEADER_ENTRY_ID=entry_id
COLUMN_HEADER_OWNER=owner_new

# --- tag mode settings ---
# Required when MODE=tag. No INPUT_FILENAME needed.
TAG=
TAG_NEW_OWNER=
# Comma-separated Kaltura entry statuses to include in the tag search.
# Defaults to all non-deleted statuses: PENDING(-1), IMPORT(0), PRECONVERT(1),
# READY(2), MODERATE(-2), BLOCKED(-3), NO_CONTENT(7).
# Set to "" to use Kaltura's own default (may exclude some statuses).
TAG_STATUS_IN=-1,0,1,2,-2,-3,7

# -----------------------------------------------------------------------------
# Execution Controls
# -----------------------------------------------------------------------------
# When true, no updates are performed. Script will only report what WOULD change.
DRY_RUN=true

# Number of concurrent workers (recommended: 10)
MAX_WORKERS=10

# Page size for baseEntry.list pagination (1–500)
PAGE_SIZE=100

# Retry/backoff configuration
MAX_RETRIES=3
BACKOFF_BASE_SEC=0.5

# Optional delay between API requests per worker (seconds)
REQUEST_DELAY_SEC=0

VALIDATE_OLD_USERS=true
VALIDATE_NEW_USERS=false
VALIDATE_PROGRESS_EVERY=10

# -----------------------------------------------------------------------------
# Timezone for output filename timestamps
# -----------------------------------------------------------------------------
TIMEZONE=America/Los_Angeles
