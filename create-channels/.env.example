# SESSION VARIABLES -----------------------------------------------------------

# Your Kaltura Partner ID (found in KMC under Settings > Integration Settings)
PARTNER_ID=

# Admin secret is entered at runtime via a secure prompt — do not store it here

# User ID for the Kaltura session (typically your email address)
USER_ID=

# Kaltura API service URL
SERVICE_URL=https://www.kaltura.com/

# SCRIPT VARIABLES ------------------------------------------------------------

# The category ID under which new channels will be created
# (usually the "channels" category in your MediaSpace instance)
PARENT_ID=

# Privacy context for channels (usually "MediaSpace")
PRIVACY_CONTEXT=MediaSpace

# The base URL of your MediaSpace instance, including the /channel/ path
# e.g., https://mediaspace.example.edu/channel/
MEDIA_SPACE_BASE_URL=

# Category fullName prefix used for duplicate detection
# Must match the fullName hierarchy in Kaltura
FULL_NAME_PREFIX=MediaSpace>site>channels>

# Filename of the input CSV (must be in the same folder as the script)
INPUT_CSV_FILENAME=channelDetails.csv

# 1=Open, 2=Restricted, 3=Private
USER_JOIN_POLICY=3

# 1=Partner Only, 3=Category Members Only
APPEAR_IN_LIST=3

# 1=Inherit, 2=Manual
INHERITANCE_TYPE=2

# 1=Contributor, 2=Moderator, 3=Member, 4=Manager
DEFAULT_PERMISSION_LEVEL=3

# 1=All Members, 2=Members with Permission
CONTRIBUTION_POLICY=2

# 0=No Moderation, 1=Moderation
MODERATION=0

# CSV COLUMN HEADERS ----------------------------------------------------------
# These must match the actual column headers in your input CSV file.

CHANNEL_NAME_HEADER=channelName
OWNER_ID_HEADER=owner
CHANNEL_MEMBERS_HEADER=members
PRIVACY_SETTING_HEADER=privacy
