# SESSION VARIABLES -----------------------------------------------------------

# Your Kaltura Partner ID (found in KMC under Settings > Integration Settings)
PARTNER_ID=

# Admin secret is entered at runtime via a secure prompt — do not store it here

# User ID for the Kaltura session (typically your email address)
USER_ID=

# SCRIPT VARIABLES ------------------------------------------------------------

# The base URL of your MediaSpace instance (e.g., https://mediaspace.example.edu)
MEDIA_SPACE_URL=

# The category ID of the new channel's parent category
PARENT_ID=

# Privacy context for the channel (usually "MediaSpace")
PRIVACY_CONTEXT=MediaSpace

# Channel name (required)
CHANNEL_NAME=

# Channel owner's Kaltura user ID
OWNER=

# Optional channel description
CHANNEL_DESCRIPTION=

# Optional: comma-separated list of Kaltura user IDs to add as members
MEMBERS=

# 1=Open, 2=Restricted, 3=Private
CHANNEL_PRIVACY=3

# 1=Auto Join, 2=Request to Join, 3=Not Allowed
USER_JOIN_POLICY=3

# 1=Partner Only, 3=Category Members Only
APPEAR_IN_LIST=3

# 1=Inherit, 2=Manual
INHERITANCE_TYPE=2

# 1=Contributor, 2=Moderator, 3=Member, 4=Manager
DEFAULT_PERMISSION_LEVEL=3

# 1=All Members, 2=Members with Permission
CONTRIBUTION_POLICY=2

# 0=No Moderation, 1=Moderation
MODERATION=0
