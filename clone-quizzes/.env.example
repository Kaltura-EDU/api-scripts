# SESSION VARIABLES -----------------------------------------------------------

# Your Kaltura Partner ID (found in KMC under Settings > Integration Settings)
PARTNER_ID=

# Admin secret is entered at runtime via a secure prompt — do not store it here

# User ID for the Kaltura session (typically your email address)
USER_ID=

# Kaltura API service URL
SERVICE_URL=https://www.kaltura.com/

# Session privileges passed to the Kaltura API
PRIVILEGES=all:*,disableentitlement

# SCRIPT VARIABLES ------------------------------------------------------------

# Comma-separated list of entry IDs of the quizzes to clone
ENTRY_IDS=

# Optional: a tag to add to each cloned entry (leave blank to skip)
TAG=
