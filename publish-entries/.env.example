# Kaltura Credentials
PARTNER_ID=your_partner_id_here
ADMIN_SECRET=your_admin_secret_here
USER_ID=your_api_user_id_here
SERVICE_URL=https://www.kaltura.com

# Kaltura session TTL in seconds (86400 = 24 hours)
SESSION_EXPIRY=86400

# Input CSV file (can also be passed as a CLI argument)
INPUT_CSV_FILENAME=input/entries_to_publish.csv

# CSV column names — change these if your CSV uses different headers
ENTRY_ID_COLUMN=entry_id
CATEGORY_ID_COLUMN=category_id

# Optional row filter — only process rows where STATUS_COLUMN == STATUS_FILTER.
# Useful for retrying failures from canvas-to-mediaspace output:
#   STATUS_COLUMN=publish_status
#   STATUS_FILTER=error
# Leave STATUS_COLUMN empty to process all rows.
STATUS_COLUMN=
STATUS_FILTER=error

# Concurrency — number of parallel publish requests
# Raise cautiously to avoid Kaltura rate limits. Recommended: 5–15.
THREAD_COUNT=10

# Total API call attempts per entry (1 = no retry, 4 = 3 retries)
MAX_RETRIES=4
