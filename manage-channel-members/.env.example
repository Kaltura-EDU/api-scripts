# Kaltura Credentials
PARTNER_ID=your_partner_id_here
ADMIN_SECRET=your_admin_secret_here
USER_ID=your_api_user_id_here
SERVICE_URL=https://www.kaltura.com

# Kaltura session TTL in seconds (86400 = 24 hours)
SESSION_EXPIRY=86400

# Input CSV file (can also be passed as a CLI argument)
INPUT_CSV_FILENAME=input/members.csv

# Concurrency — parallel API requests
# Raise cautiously to avoid Kaltura rate limits. Recommended: 5–15.
THREAD_COUNT=10

# Total API call attempts per operation (1 = no retry, 4 = 3 retries)
MAX_RETRIES=4
